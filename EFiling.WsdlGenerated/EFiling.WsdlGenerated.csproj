<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net9.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <!-- Generated by svcutil; hush cosmetic CS8981 warnings about lowercase NIEM proxy type names
         like `boolean`, `date`, `time`, `duration` — these are auto-generated and cannot be renamed
         without breaking XmlSerializer round-trip. -->
    <NoWarn>$(NoWarn);CS8981</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <!-- Required by the generated code's System.ServiceModel.* attributes
         (MessageContract, ServiceContract, XmlSerializerFormat, etc.). -->
    <PackageReference Include="System.ServiceModel.Primitives" Version="8.1.2" />
  </ItemGroup>

  <!-- Regeneration inputs preserved for reference; NOT compiled. -->
  <ItemGroup>
    <None Include="FilingReview\dotnet-svcutil.params.json" />
    <None Include="CourtRecord\dotnet-svcutil.params.json" />
  </ItemGroup>

</Project>
